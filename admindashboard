    fontSize: "28px",
    fontWeight: "700",
    marginBottom: "24px",
    color: "var(--foreground)",
};

const card = {
    background: "var(--card-bg)",
    padding: "24px",
    borderRadius: "12px",
    boxShadow: "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    marginBottom: "24px",
    border: "1px solid var(--border-color)",
};

const cardTitle = {
    fontSize: "18px",
    fontWeight: "600",
    marginBottom: "0px",
    color: "var(--foreground)",
};

const mutedText = {
    color: "var(--text-muted)",
    fontSize: "14px",
};

const tableHeader = {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    marginBottom: "12px",
};

const searchInput = {
    padding: "10px 16px",
    borderRadius: "8px",
    border: "1px solid var(--border-color)",
    backgroundColor: "var(--background)",
    color: "var(--foreground)",
    minWidth: "300px",
    fontSize: "14px",
    outline: "none",
};

const table = {
    width: "100%",
    borderCollapse: "collapse",
};

const tableHeaderCell = {
    padding: "16px 12px",
    textAlign: "left",
    borderBottom: "2px solid var(--border-color)",
    fontWeight: "600",
    color: "var(--foreground)",
    fontSize: "14px",
};

